NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
NEXTAUTH_SECRET=dev-secret-change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
INTERNAL_SECRET=

# NEXTAUTH_URL — obrigatório em produção para callbacks OAuth e links de e-mail.
# Valor atual (Vercel preview): https://poupi-frontend.vercel.app
# IMPORTANTE: atualizar para https://poupi.baby assim que o domínio for registrado e
# apontado para o Vercel. Sem isso, OAuth redirect e e-mails gerarão URLs erradas.
# Referência: https://next-auth.js.org/configuration/options#nextauth_url
NEXTAUTH_URL=http://localhost:3000

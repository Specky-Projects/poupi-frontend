# Shared frontend environment example.
# Copy app-specific values into each deployment platform, not into Git.

# Public browser-visible API base URL. Do not put secrets here.
NEXT_PUBLIC_API_URL=https://api.example.com

# Server-side backend URL for Next.js route handlers and server components.
# In production, prefer an internal Docker/Coolify service URL.
BACKEND_URL=http://data-core:8000

# Public canonical site URL for generated metadata, sitemap and robots.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Optional observability. DSN values are not passwords, but keep production values in deployment secrets.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
